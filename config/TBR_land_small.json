{
  "hidden_size": 32,
  "topo_net": [
    {"type": "Linear", "in_features": 500, "out_features": 128},
    {"type": "ReLU"},
    {"type": "Linear", "in_features": 128, "out_features": 64},
    {"type": "ReLU"},
    {"type": "Linear", "in_features": 64, "out_features": 32},
    {"type": "ReLU"}
  ],

  "res_net_fc": [  {"type": "Linear", "in_features": 512, "out_features": 128},
    {"type": "ReLU"},
    {"type": "Linear", "in_features": 128, "out_features": 32},
    {"type": "ReLU"}],

  "fc": [  {"type": "Linear", "in_features": 64, "out_features": 32},
      {"type": "ReLU"},
      {"type": "Linear", "in_features": 32, "out_features": 16},
      {"type": "ReLU"},
      {"type": "Linear", "in_features": 16, "out_features": 10},
      {"type": "Softmax", "dim": 1}]
}
